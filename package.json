{
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "prisma",
      "@prisma/engines",
      "msgpackr-extract",
      "esbuild"
    ]
  },
  "name": "opsflow-ai",
  "version": "1.0.0",
  "description": "OpsFlow AI - Monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "seed": "pnpm --filter @opsflow/db seed",
    "postinstall": "pnpm --filter @opsflow/db generate",
    "start": "npx tsx apps/worker/src/index.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.2",
  "devDependencies": {
    "turbo": "^2.9.12"
  }
}
